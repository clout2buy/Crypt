# Copy to `.env` only if you want env vars to override saved setup.
# Setup is optional; a fresh clone defaults to Ollama in the current directory.
#   python main.py

# Workspace. If unset, crypt uses saved setup, then current directory.
# CRYPT_ROOT=D:\your-project
# CRYPT_TRACE=1
# CRYPT_TRACE_PATH=
# CRYPT_APPROVAL=edits  # edits (default), normal, or all
# CRYPT_REASONING_STALL_SECONDS=45
# Target evals forbid .env and common live DB paths by default.
# CRYPT_REQUIRE_SETUP=0
# CRYPT_PICKER=0

# Provider: anthropic, openai, openai-codex, or ollama.
CRYPT_PROVIDER=ollama

# Anthropic OAuth. Use `python main.py login` or choose Anthropic in setup.
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_THINKING_BUDGET=512

# OpenAI or OpenAI-compatible endpoints.
OPENAI_MODEL=gpt-5
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ChatGPT OAuth / Codex subscription backend.
OPENAI_CODEX_MODEL=gpt-5-codex
# OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api
# OPENAI_CODEX_REASONING_EFFORT=medium

# Local Ollama. Start it with `ollama serve`.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b
# Keep this at 0 for faster tool calls. Raise it if you want model reasoning.
OLLAMA_THINKING_BUDGET=0
# OLLAMA_API_KEY=  # cloud only; Anthropic login is not used for Ollama
