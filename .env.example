# Copy to `.env` only if you want env vars to override saved setup.
# Normal setup is interactive:
#   python main.py setup

# Workspace. If unset, crypt uses saved setup, then current directory.
# CRYPT_ROOT=D:\your-project

# Provider: anthropic or ollama.
# CRYPT_PROVIDER=anthropic

# Anthropic OAuth. Use `python main.py login` or choose Anthropic in setup.
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_THINKING_BUDGET=1024

# Ollama Cloud.
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b-cloud
# OLLAMA_API_KEY=
